# ═══════════════════════════════════════════════════════════════
#  Dubizzle Scraper — Telegram Bot Configuration
# ═══════════════════════════════════════════════════════════════
#
#  1. Create a Telegram Bot:
#     → Open Telegram, search for @BotFather, send /newbot
#     → Follow the prompts to pick a name & username
#     → BotFather replies with your token (e.g. 7123456789:AAH...")
#     → Paste it below as TELEGRAM_BOT_TOKEN
#
#  2. Get your Chat ID:
#     → Send any message to your new bot in Telegram
#     → Open: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#     → Find "chat":{"id": <NUMBER>} in the JSON response
#     → Paste that number below as TELEGRAM_CHAT_ID
#
#  3. Run the scraper:
#     → bun run scrape-dubizzle.ts
#
# ═══════════════════════════════════════════════════════════════

# Your Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram Chat ID (your personal chat with the bot)
TELEGRAM_CHAT_ID=
