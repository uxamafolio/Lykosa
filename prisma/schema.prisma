// ═══════════════════════════════════════════════════════════════
// Lykosa — AI-Powered Real Estate Lead Hunter
// Data Models per PRD v2.1, Section 5.3
// PostgreSQL deployment target for Supabase.
// blacklistKeywords stays JSON-encoded so the app can keep one portable shape.
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Listing ──────────────────────────────────────────────────
model Listing {
  id              String    @id @default(cuid())
  title           String
  price           Float     @default(0)
  url             String    @unique
  source          String    @default("dubizzle")

  phone           String?
  agentScore      Int       @default(0)

  sourceListedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Status: "NEW" | "SENT" | "IGNORED"
  status          String    @default("NEW")

  @@index([phone])
  @@index([agentScore])
  @@index([status])
  @@index([createdAt])
}

// ─── AdminSetting ─────────────────────────────────────────────
// blacklistKeywords is stored as a JSON string, e.g. '["agent","broker"]'
model AdminSetting {
  id                String  @id @default(cuid())

  // JSON-encoded string array, e.g. '["agent","broker"]'
  blacklistKeywords String  @default("[]")

  // Scrape interval in minutes (default: 10)
  scrapeInterval    Int     @default(10)

  // "ALL" | "VERIFIED_ONLY"  (PRD §4.4 Shadow Mode)
  notifyMode        String  @default("ALL")

  // Agent score threshold (0–100). Listings above this are "Likely Agent"
  agentThreshold    Int     @default(60)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
